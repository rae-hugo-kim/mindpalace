{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/scope-gate.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node .claude/hooks/harness/context-gate.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/destructive-guard.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node .claude/hooks/harness/acceptance-gate.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node .claude/hooks/harness/backpressure-gate.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node .claude/hooks/harness/review-gate.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/mcp-gate.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/read-tracker.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/backpressure-tracker.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/backpressure-invalidator.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/kickoff-detector.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/harness/harness-version-check.mjs",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

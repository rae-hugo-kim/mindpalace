
# Local files
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/agents/
!.claude/settings.json
docs/sum/
docs/brainstorming/
docs/reviews/
docs/harness/*-skip
docs/harness/*-done

# OMC state and sessions (transient)
.omc/
bun-linux-x64/

# mdBook
book/
mermaid.min.js
mermaid-init.js

# Human-facing one-off HTML artifacts (see artifacts/README.md)
# Pattern: ignore everything under artifacts/, but keep README.md at any depth
# so subdirectory structure is documented (recursive ** for nested subdirs).
artifacts/**
!artifacts/**/
!artifacts/README.md
!artifacts/**/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# venv
.venv/
venv/

# pytest
.pytest_cache/
.coverage
htmlcov/

# uv
uv.lock

# DB (local data)
*.db
*.sqlite
*.sqlite3
data/
